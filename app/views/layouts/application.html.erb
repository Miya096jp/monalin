<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Monalin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Monalin">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="menu">
    <% if current_user %>
      <p><%= "ログイン中: #{current_user.username}" %></p>
    <% else %>
      <p>ログインしていません</p>
    <% end %>

    <header>
      <button type="button" data-action="click->menu#open">
        ☰
      </button>
      <%= link_to "Monalin" %>
    </header>

    <div
      data-menu-target="overlay"
      data-action="click->menu#close"
      class="
        fixed inset-0 bg-black/50 z-40 invisible opacity-0 transition-opacity
        duration-300
      "
    >
    </div>

    <aside
      id="menu"
      data-menu-target="aside"
      class="
        fixed top-0 left-0 h-full w-[90%] bg-gray-50 border-r z-50 flex flex-col p-4
        transition-transform duration-300 ease-out -translate-x-full
      "
    >
      <div class="flex justify-end">
        <button type="button" aria-label="メニューを閉じる" data-action="click->menu#close">
          ✕
        </button>
      </div>
      <nav>
        <ul class="flex flex-col gap-2">
          <li><%= link_to "新しいセッション", new_session_path %></li>
          <li><%= link_to "使い方", "#" %></li>
        </ul>
      </nav>

      <div id="session-list" class="flex-1 overflow-y-auto mt-4">
        <%= render "sessions/session_list", sessions: @sidebar_sessions %>
      </div>

      <div
        class="mt-4 relative"
        data-controller="submenu"
        data-action="click@window->submenu#close"
      >
        <button type="button" class="text-xl" data-action="click->submenu#toggle">
          &#x2026;
        </button>
        <div class="hidden" data-submenu-target="list">
          <ul
            class="
              flex flex-col gap-2 bg-white border rounded-lg p-4 absolute bottom-10 left-0
            "
          >
            <li><%= link_to "アカウント設定", "#" %></li>
            <li><%= link_to "アプリ設定", "#" %></li>
            <li><%= link_to "利用規約", "#" %></li>
            <li><%= link_to "プライバシーポリシー", "#" %></li>
            <li><%= link_to "お問い合わせ", "#" %></li>
            <li><%= link_to "About", "#" %></li>
            <li><%= button_to "ログアウト", login_path, method: :delete %></li>
          </ul>
        </div>
      </div>
    </aside>
    <main>
      <%= yield %>
    </main>
  </body>
</html>
